{
  "name": "lms",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:web": "npm run dev -w @lms/web",
    "dev:api": "npm run start:dev -w @lms/api",
    "build:web": "npm run build -w @lms/web",
    "build:api": "npm run build -w @lms/api",
    "lint:web": "npm run lint -w @lms/web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "devDependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
